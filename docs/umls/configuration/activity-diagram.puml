@startuml

start

:Разбор аргументов командной строки;

if (Команда?) then (setup)
  :Проверить, что запуск не от root;
  :Создать каталог /var/lib/rebos/;
  :Создать подкаталог generations/;
  :Создать файлы current и built;
  :Вывести сообщение об успехе;
  stop
elseif (config init) then
  :Создать каталог ~/.config/rebos/;
  :Создать файл gen.toml с шаблоном;
  :Создать подкаталог managers/;
  :Создать файл managers/system.toml;
  :Вывести сообщение об успехе;
  stop
elseif (config check) then
  :Проверить синтаксис gen.toml;
  :Проверить файлы менеджеров в managers/;
  if (ошибки есть?) then (да)
    :Вывести сообщение об ошибке;
    stop
  else (нет)
    :Вывести сообщение об успехе;
    stop
  endif
elseif (gen list) then
  :Прочитать current и built из /var/lib/rebos/;
  :Получить список подкаталогов в generations/;
  :Отфильтровать нечисловые имена;
  :Сортировать поколения по возрастанию;
  while (есть необработанные поколения?) is (да)
    :Прочитать commit-сообщение;
    :Определить, является ли поколение текущим/собранным;
    :Вывести строку с номером, сообщением и метками;
  endwhile (нет)
  stop
elseif (gen commit) then
  :Выполнить проверку конфигурации (аналог config check);
  :Определить номер нового поколения (max+1);
  :Создать каталог generations/<N>/;
  :Сохранить пользовательскую конфигурацию в gen.toml;
  :Записать commit-сообщение в файл commit;
  :Записать номер N в current;
  :Вывести сообщение об успехе;
  stop
elseif (gen current set) then
  :Проверить существование поколения N;
  if (поколение не существует?) then (да)
    :Выдать ошибку;
    stop
  else (нет)
    :Записать N в файл current;
    :Вывести сообщение об успехе;
    stop
  endif
elseif (gen current build) then
  :Загрузить gen.toml текущего поколения;
  :Загрузить последнее собранное поколение (built);
  :Рассчитать различия (добавить/удалить);
  :Выполнить удаление элементов;
  :Выполнить добавление элементов;
  :Записать номер текущего поколения в built;
  :Вывести отчёт (добавлено/удалено);
  stop
else
  :Выдать ошибку;
  stop
endif

@enduml
